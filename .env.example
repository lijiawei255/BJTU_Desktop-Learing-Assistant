# .env.example — 环境变量模板
#
# 将此文件复制为 .env 并填入你的实际密钥：
#   cp .env.example .env
#
# 注意：.env 文件包含敏感信息，已被 .gitignore 排除，请勿提交到 Git。

# 阿里云百炼 API Key（必需）
# 获取地址：https://bailian.console.aliyun.com/
ALIBABA_API_KEY=sk-
# 以下为可选配置

# 自定义音频设备索引（当有多个音频设备时使用）
# AUDIO_INPUT_DEVICE_INDEX=1
# AUDIO_OUTPUT_DEVICE_INDEX=3

# Mock 模式开关（阶段一 PC 开发时启用，阶段二树莓派部署时关闭）
# ENABLE_MOCK=true

# 日志级别：DEBUG / INFO / WARNING / ERROR
# LOG_LEVEL=DEBUG
