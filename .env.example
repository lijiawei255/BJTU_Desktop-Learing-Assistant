# .env.example — 环境变量模板
#
# 将此文件复制为 .env 并填入你的实际密钥：
#   cp .env.example .env
#
# 注意：.env 文件包含敏感信息，已被 .gitignore 排除，请勿提交到 Git。

# 阿里云百炼 API Key（必需）
# 获取地址：https://bailian.console.aliyun.com/
ALIBABA_API_KEY=sk-your-api-key-here

# 以下为可选配置（树莓派部署时按需取消注释）

# ── 音频设备索引 ──
# 当有多个音频设备时（如USB声卡+板载音频），固定设备索引避免选错。
# 先在树莓派上运行 `python -m tests.test_real_audio` 查看每个设备的索引号。
# UACDemoV1.0 USB声卡通常为 index 1（录音）和 index 1（播放）。
# AUDIO_INPUT_DEVICE_INDEX=1
# AUDIO_OUTPUT_DEVICE_INDEX=1

# ── Mock 模式开关 ──
# 设置为 false 可覆盖 config.json 的 mock.enabled（无需改文件即可切换到真实硬件）。
# ENABLE_MOCK=false

# ── 日志级别 ──
# DEBUG / INFO / WARNING / ERROR
# LOG_LEVEL=INFO
